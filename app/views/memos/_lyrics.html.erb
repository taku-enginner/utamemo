<turbo-frame id="lyrics"">
  <% if lyrics_result && !!lyrics_result.split(/\*{7,}/).first %>
    <% lyrics_result = (lyrics_result.split(/\*{7,}/).first.strip) %>
    <div class="flex">
      <div class="mx-5 mt-10 mb-10 pt-10 text-white text-2xl max-w-[335px]">
        <%= simple_format(h(lyrics_result.gsub(/\n/,'<br><br><br><br><br>').html_safe)) %>
      </div>
    </div>
    <div class="text-white font-bold text-3xl py-10 m-10 text-center border border-white">
      申し訳ありません。<br>
      ライセンスの関係で、歌詞の取得がここまでしかできません。
    </div>
  <% else %>
    <div class="flex flex-col items-center justify-center min-h-screen bg-gray-100 p-4 hidden" id="not-found">
      <div class="max-w-md w-full p-6 bg-white rounded-lg shadow-sm text-center">
        <h2 class="text-xl font-bold mb-4">メモが見つかりません</h2>
        <p class="text-gray-600 mb-4">指定されたメモが存在しないか、データが正しく読み込まれていません。</p>
        <%= link_to "ホームに戻る", root_path, class="inline-block px-4 py-2 bg-purple-600 text-white rounded-md hover:bg-purple-700"%>
      </div>
    </div>
  <% end %>
</turbo-frame>